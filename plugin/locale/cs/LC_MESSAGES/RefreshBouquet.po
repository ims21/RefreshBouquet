msgid "Manually replace programs in the target bouquet with programs from the source bouquet."
msgstr "Ruční nahrazování programů v cílovém přehledu programy ze zdrojového přehledu."

#: ../rbbmanager.py:77 ../ui.py:246
msgid "Manually replace services"
msgstr "Ruční nahrazování programů"

#: ../ui.py:2498
msgid "Mark service(s) with OK button or use group selection (Ch+/Ch-), move selector to new position and finish with 'Move selected'. Selected service(s) will be moved top new position."
msgstr "Označte programy pomocí 'OK' nebo skupinového výběru (Ch+/Ch-), přesuňte kurzor na novou pozici a dokončete tlačítkem 'Přesunout vybrané'. Označené programy budou přesunuty nad novou pozici."

#: ../ui.py:2079
msgid "Mark services with OK button or use group selection (Ch+/Ch-) and then copy these with 'Copy selected'."
msgstr "Označte programy pomocí 'OK' nebo skupinového výběru (Ch+/Ch-)  a pak je zkopírujte  tlačítkem 'Zkopírovat vybrané'."

#: ../ui.py:2293
msgid "Mark services with OK button or use group selection (Ch+/Ch-) and then remove these with 'Remove selected'."
msgstr "Označte programy pomocí 'OK' nebo skupinového výběru (Ch+/Ch-) a pak je odstraňte tlačítkem 'Odstranit vybrané'."

#: ../ui.py:1575
msgid "Marking can be canceled with key '0'."
msgstr "Označení může být zrušeno klávesou '0'."

#: ../ui.py:2762
msgid "Missing source services for manually replace only"
