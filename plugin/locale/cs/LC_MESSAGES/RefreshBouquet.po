#: ../ui.py:252
msgid "Move one service or more selected services in bouquet to new position."
msgstr "Přemístí najednou jeden nebo více vybraných programů v přehledu na novou pozici."

#: ../ui.py:2494
msgid "Move selected"
msgstr "Přesunout vybrané"

#: ../ui.py:252
msgid "Move selected services in bouquet"
